+/* ── policy preview ───────────────────────────────────── */
+async function refreshPolicies(){
+  try{
+    const r = await fetch(API + "/documents");
+    if(!r.ok) return;
+    const docs = await r.json();
+    if(!Array.isArray(docs) || !docs.length) return;
+    policiesLoaded = true;
+    const ul = $("policy-list"); ul.innerHTML = "";
+    for(const d of docs){
+      const name = (d.filename||"policy").replace(/\.pdf$/i,"");
+      const li = document.createElement("li");
+      li.className = "flex items-start gap-2";
+      li.innerHTML = `<span class="material-symbols-outlined text-primary/70 text-[16px] mt-0.5">description</span><span>${esc(name)}</span>`;
+      ul.appendChild(li);
+    }
+    $("policy-count").textContent = `${docs.length} loaded ${docs.length===1?"policy":"policies"} — click to preview`;
+    $("policy-panel").style.display = "block";
+    const chatBtn = $("home-chat");
