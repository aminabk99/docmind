# ── M365Mind environment variables ──────────────────────────────────────────
# Copy this file to .env and fill in your values.

# Backend URL (Streamlit frontend uses this to talk to FastAPI)
BACKEND_URL=http://localhost:8000

# ChromaDB storage path (relative to project root)
CHROMA_DB_PATH=./chroma_db

# ── Microsoft 365 / Entra ID (required for real-tenant mode) ────────────────
# Register an app at https://portal.azure.com → Entra ID → App registrations
# Required API permissions: Policy.Read.All, InformationProtectionPolicy.Read.All
# Set redirect URI to: http://localhost:8000/callback
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=http://localhost:8000/callback

# ── Demo mode ────────────────────────────────────────────────────────────────
# Set to true to automatically load demo data on startup (optional)
DEMO_MODE=false
